{
    "name": "aurigma/rendering-service-api-client",
    "description": "PHP API Client for Rendering Service of Customer's Canvas web-to-print system.",
    "keywords": [
        "customers canvas",
        "web-to-print",
        "api client",
        "rendeirng"
    ],
    "homepage": "https://customerscanvas.com",
    "license": "proprietary",
    "authors": [
        {
            "name": "Aurigma Inc",
            "email": "info@aurigma.com",
            "homepage": "https://customerscanvas.com"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0",
        "jumbojett/openid-connect-php": "^0.9.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": { "Aurigma\\RenderingService\\" : "lib/" }
    },
    "autoload-dev": {
        "psr-4": { "Aurigma\\RenderingService\\Test\\" : "test/" }
    }
}